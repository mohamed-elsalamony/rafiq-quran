<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- Top Section: Prayer Times -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Countdown on Left -->
        <TextView
            android:id="@+id/widget_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--:--"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Prayer Info on Right -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/widget_prayer_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الصلاة القادمة"
                android:textColor="#D4AF37"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_prayer_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="في --:--"
                android:textColor="#A5D6A7"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Separator Line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33D4AF37"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

    <!-- Bottom Section: Ayah of the day -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="آية اليوم"
        android:textColor="#E2ECE9"
        android:textSize="10sp"
        android:textStyle="bold"
        android:gravity="end" />

    <TextView
        android:id="@+id/widget_ayah"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="﴿ إِنَّ هَٰذَا الْقُرْآنَ يَهْدِي لِلَّتِي هِيَ أَقْوَمُ ﴾"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="normal"
        android:gravity="center"
        android:layout_marginTop="4dp"
        android:maxLines="3"
        android:ellipsize="end" />
</LinearLayout>
