<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="horizontal"
    android:padding="14dp">

    <!-- Left Column: The 5 prayer times -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.2"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingEnd="8dp">

        <!-- Row Fajr -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/widget_fajr_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"/>
            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الفجر"
                android:textColor="#E2ECE9"
                android:textSize="11sp"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1FD4AF37" android:layout_marginTop="3dp" android:layout_marginBottom="3dp"/>

        <!-- Row Dhuhr -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/widget_dhuhr_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"/>
            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الظهر"
                android:textColor="#E2ECE9"
                android:textSize="11sp"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1FD4AF37" android:layout_marginTop="3dp" android:layout_marginBottom="3dp"/>

        <!-- Row Asr -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/widget_asr_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"/>
            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="العصر"
                android:textColor="#E2ECE9"
                android:textSize="11sp"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1FD4AF37" android:layout_marginTop="3dp" android:layout_marginBottom="3dp"/>

        <!-- Row Maghrib -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/widget_maghrib_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"/>
            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="المغرب"
                android:textColor="#E2ECE9"
                android:textSize="11sp"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1FD4AF37" android:layout_marginTop="3dp" android:layout_marginBottom="3dp"/>

        <!-- Row Isha -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/widget_isha_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"/>
            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="العشاء"
                android:textColor="#E2ECE9"
                android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Vertical Splitter Line -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#33D4AF37"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="10dp"/>

    <!-- Right Column: Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.8"
        android:orientation="vertical"
        android:gravity="end">

        <!-- App name & Next prayer countdown -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/widget_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="#D4AF37"
                android:textSize="15sp"
                android:textStyle="bold"/>
            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
            <TextView
                android:id="@+id/widget_prayer_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الصلاة القادمة"
                android:textColor="#A5D6A7"
                android:textSize="11sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#15D4AF37" android:layout_marginTop="4dp" android:layout_marginBottom="4dp"/>

        <!-- Ayah -->
        <TextView
            android:id="@+id/widget_ayah"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="آية اليوم..."
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:gravity="end|center_vertical"
            android:maxLines="2"
            android:ellipsize="end"/>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#15D4AF37" android:layout_marginTop="4dp" android:layout_marginBottom="4dp"/>

        <!-- Hadith -->
        <TextView
            android:id="@+id/widget_hadith"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1.2"
            android:text="حديث اليوم..."
            android:textColor="#E2ECE9"
            android:textSize="10sp"
            android:gravity="end|center_vertical"
            android:maxLines="2"
            android:ellipsize="end"/>
    </LinearLayout>
</LinearLayout>
